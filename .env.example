# Database
# Default (zero-config, works out of the box): SQLite
DATABASE_URL=sqlite+aiosqlite:///./billing.db

# To use PostgreSQL instead, comment the line above and uncomment/edit below:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/billing_db

# SMTP settings for sending invoice emails.
# If left blank, the app will NOT fail — it will simply log the invoice
# instead of emailing it (see README "Assumptions").
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=arulvadivel1103@gmail.com
SMTP_PASSWORD=rspr rcrf lvcq rumz
SMTP_FROM_EMAIL=arulvadivel1103@gmail.com
SMTP_USE_TLS=true
